{
    "name": "sigcli",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "pnpm -r build",
        "test": "pnpm -r test",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,js}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import-x": "^4.16.2",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.2",
        "typescript": "^5.3.0",
        "typescript-eslint": "^8.58.1"
    },
    "author": "pylon <pylon.peng@gmail.com>",
    "license": "MIT",
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "lightningcss"
        ],
        "overrides": {
            "vite@7": "^7.3.5",
            "esbuild@0.27": "^0.28.1",
            "hono": "^4.12.25",
            "fast-uri": "^3.1.2",
            "ws": "^8.21.0",
            "qs": "^6.15.2",
            "ip-address": "^10.1.1",
            "js-yaml": "^4.2.0",
            "shell-quote": "^1.8.4",
            "launch-editor": "^2.14.1",
            "@babel/core": "^7.29.6",
            "@tanstack/start-server-core": "^1.167.30",
            "brace-expansion": "^5.0.6",
            "@tanstack/start-plugin-core": "^1.171.0",
            "@tanstack/react-start": "^1.168.0"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/sigcli/sigcli.git"
    }
}
