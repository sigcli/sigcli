{
    "name": "@sigcli/cli",
    "version": "1.6.14",
    "description": "General-purpose authentication CLI with pluggable strategies and browser adapters",
    "main": "dist/index.js",
    "type": "module",
    "bin": {
        "sig": "./bin/sig.js"
    },
    "files": [
        "dist/",
        "bin/"
    ],
    "scripts": {
        "build": "tsc",
        "prepack": "pnpm run build",
        "start": "node bin/sig.js",
        "dev": "tsc && node bin/sig.js",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@peculiar/x509": "^2.0.0",
        "croner": "^10.0.1",
        "dlv": "^1.1.3",
        "proper-lockfile": "^4.1.2",
        "undici": "^7.28.0",
        "yaml": "^2.7.0"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@types/dlv": "^1.1.5",
        "@types/node": "^20.10.0",
        "@types/proper-lockfile": "^4.1.4",
        "prettier": "^3.8.3",
        "reflect-metadata": "^0.2.2",
        "vitest": "^3.2.6"
    },
    "keywords": [
        "cli",
        "auth",
        "authentication",
        "oauth2",
        "browser"
    ],
    "author": "pylon <pylon.peng@gmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/sigcli/sigcli.git",
        "directory": "cli"
    },
    "engines": {
        "node": ">=20.18.1"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    }
}
