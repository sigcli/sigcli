{
    "name": "@sigcli/sdk",
    "version": "1.1.0",
    "description": "Lightweight client SDK for consuming sigcli credentials",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist/"
    ],
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/sigcli/sigcli.git",
        "directory": "sdk/typescript"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "devDependencies": {
        "@types/node": "^20.17.0",
        "typescript": "^5.5.0",
        "vitest": "^2.0.0"
    }
}
